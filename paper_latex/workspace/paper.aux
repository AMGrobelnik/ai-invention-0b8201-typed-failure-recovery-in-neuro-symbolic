\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces End-to-end neuro-symbolic pipeline: (1) LLM extracts FOL predicates from natural text with source-span annotations; (2) facts loaded into Prolog KB; (3) query execution may fail; (4) typed failure detector classifies failure type via exception inspection and ontology lookup; (5) type-specific repair prompt dispatched; (6) repair verified via re-run; (7) Type~1 repairs cached for reuse.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:pipeline}{{1}{4}{End-to-end neuro-symbolic pipeline: (1) LLM extracts FOL predicates from natural text with source-span annotations; (2) facts loaded into Prolog KB; (3) query execution may fail; (4) typed failure detector classifies failure type via exception inspection and ontology lookup; (5) type-specific repair prompt dispatched; (6) repair verified via re-run; (7) Type~1 repairs cached for reuse}{figure.1}{}}
